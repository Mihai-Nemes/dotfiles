#!/bin/bash

# --- Personal Aliases ---
# Easier navigation and directory listings
alias ll='ls -la'          # Lists all files, including hidden ones, with details
alias ..='cd ..'           # Quickly go up one folder
alias ...='cd ../..'       # Quickly go up two folders

# Git Shortcuts (Saves massive amounts of typing)
alias gs='git status'
alias ga='git add'
alias gaa='git add .'
alias gc='git commit -m'
alias gp='git push'
alias gl='git log --oneline --graph --decorate'

# --- Custom Terminal Welcome Message ---
echo "========================================="
echo "       🚀 CODEPACE SKILLS LOADED        "
echo "========================================="
