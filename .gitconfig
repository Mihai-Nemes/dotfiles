[user]
    # Codespaces usually fills your name/email automatically, 
    # but you can hardcode it here if you prefer.
    name = Your Name
    email = your-email@example.com

[core]
    # Uses VS Code as your default text editor for git commit messages
    editor = code --wait

[init]
    # Ensures all your new local repositories use 'main' instead of 'master'
    defaultBranch = main

[color]
    # Makes your terminal git output beautifully color-coded
    ui = auto

[alias]
    # If you prefer git native aliases over bash aliases:
    co = checkout
    br = branch
    st = status
