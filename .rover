# .rover - Rover Project Configuration
# Stores artifacts and skills for the Rover project

project:
  name: Rover
  description: A personal rover project

artifacts:
  # List your project artifacts here
  # Example entries:
  # - name: rover-firmware
  #   type: firmware
  #   version: 1.0.0
  #   path: ./firmware
  #   description: Main firmware for the rover

skills:
  # List your skills used in this project here
  # Example entries:
  # - name: Python
  #   level: intermediate
  #   category: programming
  # - name: ROS
  #   level: beginner
  #   category: robotics
